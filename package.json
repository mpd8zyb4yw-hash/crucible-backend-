{
  "name": "crucible",
  "main": "electron.cjs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx tsx server.ts\" \"npx vite\"",
    "server": "tsx server.ts",
    "smoke": "tsx src/CrucibleEngine/smoke-benchmarks.ts",
    "test:local": "tsx src/CrucibleEngine/localModels/__router_bench.ts && tsx src/CrucibleEngine/localModels/__onnx_bench.ts && tsx src/CrucibleEngine/localModels/strengthen/__strengthen_bench.ts && tsx src/CrucibleEngine/localModels/__ensemble_bench.ts",
    "diag": "curl -s http://localhost:3001/api/diag | python3 -m json.tool",
    "build": "tsc -b && vite build",
    "build:app": "bash setup-crucible.sh",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "wait-on --timeout 30000 http://localhost:5173 http://localhost:3001 && sleep 3 && npx electron electron.cjs",
    "predev": "pkill -f \"tsx server\" || true; pkill -f \"vite\" || true; lsof -ti:5173 | xargs kill -9 2>/dev/null || true; lsof -ti:3001 | xargs kill -9 2>/dev/null || true; sleep 1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^2.2.5",
    "@types/compression": "^1.8.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright-core": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
